datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model UserState {
  userId  String  @id
  step    Boolean @default(false)
  tickets String?
  number  Int?
  name    String?
}

model TShirtStock {
  id    Int    @id @default(autoincrement())
  size  String @unique
  stock Int    @default(0)
}
